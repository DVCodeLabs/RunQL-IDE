+function compareNumericVersionPart(a: string, b: string): number {
+	const normalizedA = a.replace(/^0+(?=\d)/, '');
+	const normalizedB = b.replace(/^0+(?=\d)/, '');
+
+	if (/^\d+$/.test(normalizedA) && /^\d+$/.test(normalizedB)) {
+		if (normalizedA.length !== normalizedB.length) {
+			return normalizedA.length > normalizedB.length ? 1 : -1;
+		}
+
+		if (normalizedA !== normalizedB) {
+			return normalizedA > normalizedB ? 1 : -1;
+		}
+
+		return 0;
+	}
+
+	return normalizedA.localeCompare(normalizedB);
+}
+
+function compareVersionStrings(currentVersion: string, updateVersion: string): number {
+	const currentParts = currentVersion.replace(/^[vV]/, '').replace(/-insider$/, '').split('.');
+	const updateParts = updateVersion.replace(/^[vV]/, '').replace(/-insider$/, '').split('.');
+	const length = Math.max(currentParts.length, updateParts.length);
+
+	for (let i = 0; i < length; i++) {
+		const result = compareNumericVersionPart(currentParts[i] ?? '0', updateParts[i] ?? '0');
+
+		if (result !== 0) {
+			return result;
+		}
+	}
+
+	return 0;
+}
+
+export function compareUpdateVersions(currentVersion: string, update: IUpdate): number {
+	return compareVersionStrings(currentVersion, update.name || update.productVersion);
+}
